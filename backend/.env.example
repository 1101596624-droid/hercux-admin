# Environment
ENV=production

# Server
HOST=0.0.0.0
PORT=8001
DEBUG=False

# Database (SQLite for simple deployment)
DATABASE_URL=sqlite+aiosqlite:////www/wwwroot/hercu-backend/hercu.db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# Redis (optional - app works without it)
REDIS_URL=redis://localhost:6379/0

# Neo4j (optional - app works without it)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# JWT
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1800

# Claude AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# DeepSeek AI (optional)
DEEPSEEK_API_KEY=your-deepseek-api-key

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=hercu-content

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
